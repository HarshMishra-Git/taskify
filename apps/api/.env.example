DATABASE_URL=postgresql://user:password@db:5432/taskify
SECRET_KEY=change-me-to-a-long-random-secret-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ZeptoMail — key only, WITHOUT the "Zoho-enczapikey" prefix
ZEPTO_API_KEY=
ZEPTO_FROM_EMAIL=noreply@yourdomain.com
ZEPTO_FROM_NAME=Taskify

# Base URL used in email links (your deployed frontend URL)
FRONTEND_URL=http://localhost:3003
